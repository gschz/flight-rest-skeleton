# =============================================================================
# .envs/.env.production.example — Production environment template
# =============================================================================
# DO NOT copy this as-is. Set these variables via your platform's dashboard
# (Heroku config vars, Railway variables, etc.).
# This file is a reference only — it is tracked in git with no real values.
# =============================================================================

APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:CHANGE_ME_run_openssl_rand_-base64_32_and_keep_secret

# On Heroku/Railway: DATABASE_URL is set automatically when you add a Postgres addon
DATABASE_URL=pgsql://user:pass@host:5432/dbname?sslmode=require

# Or set individual vars:
# DB_CONNECTION=pgsql
# DB_HOST=your-db-host
# DB_PORT=5432
# DB_DATABASE=your-db-name
# DB_USERNAME=your-db-user
# DB_PASSWORD=your-db-password
# DB_SSLMODE=require

CORS_ALLOWED_ORIGINS=https://yourdomain.com
LOG_LEVEL=error

# Rate Limiting (DB-based)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# JWT Authentication — use a strong random secret of at least 32 bytes
# Generate with: openssl rand -base64 32
JWT_SECRET=base64:CHANGE_ME_run_openssl_rand_-base64_32_and_keep_secret
JWT_TTL=3600
JWT_REFRESH_TTL=604800
